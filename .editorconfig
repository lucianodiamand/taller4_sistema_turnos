root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Java: alineado con googleJavaFormat (2 espacios). Si se cambia a
# palantirJavaFormat en build.gradle, ajustar indent_size = 4.
[*.java]
indent_style = space
indent_size = 2

[*.{ts,html,scss,json,yml,yaml}]
indent_style = space
indent_size = 2

[*.{gradle,xml}]
indent_style = tab
